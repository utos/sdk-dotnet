<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Utos.Daemon.Server</PackageId>
    <RootNamespace>Utos.Daemon</RootNamespace>
    <Description>Utos daemon gRPC SERVER stubs (utos.daemon.v1): use this to implement a Utos daemon in .NET. Contains the daemon message types and the service base classes only (no client). Generated from the Utos API specification.</Description>
    <PackageTags>utos;daemon;grpc;server;protobuf</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Grpc.Core.Api" />
    <PackageReference Include="Grpc.Tools" PrivateAssets="all" />
  </ItemGroup>

  <!-- Workflow message types resolve from this reference (NOT regenerated here). -->
  <ItemGroup>
    <ProjectReference Include="..\Utos.Workflow\Utos.Workflow.csproj" />
  </ItemGroup>

  <!-- Daemon DTOs + SERVER stubs (GrpcServices="Server" => no_client). See Client csproj for ProtoRoot rationale. -->
  <ItemGroup>
    <Protobuf Include="..\..\proto\daemon\v1\*.proto"
              ProtoRoot="..\..\proto"
              GrpcServices="Server"
              OutputDir="Generated"
              CompileOutputs="true" />
    <!-- shared.proto declares no service, so it emits no *Grpc.cs. -->
    <Protobuf Update="..\..\proto\daemon\v1\shared.proto" GrpcServices="None" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\proto\daemon\**\*.proto" Pack="true" PackagePath="proto\daemon\" Visible="false" />
    <None Include="..\..\CHANGELOG.md" Pack="true" PackagePath="docs\" Visible="false" />
  </ItemGroup>

</Project>
